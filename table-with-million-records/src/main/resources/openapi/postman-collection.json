            "url": {
              "raw": "{{baseUrl}}/private-app/bank-accounts/actions/filter",
              "host": ["{{baseUrl}}"],
              "path": ["private-app", "bank-accounts", "actions", "filter"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"accountType\": \"SAVINGS\",\n  \"status\": \"ACTIVE\",\n  \"pagination\": {\n    \"pageSize\": 20,\n    \"pageNumber\": 0,\n    \"sortBy\": \"sequenceNumber\",\n    \"sortOrder\": \"ASC\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Filter bank accounts using offset-based pagination. All filter fields are optional."
          },
          "response": []
        },
        {
          "name": "Filter Bank Accounts (Cursor Pagination)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/private-app/bank-accounts/actions/filter-cursor",
              "host": ["{{baseUrl}}"],
              "path": ["private-app", "bank-accounts", "actions", "filter-cursor"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountType\": \"SAVINGS\",\n  \"status\": \"ACTIVE\",\n  \"pagination\": {\n    \"pageSize\": 20,\n    \"sortBy\": \"sequenceNumber\",\n    \"sortOrder\": \"ASC\",\n    \"nextPageToken\": null,\n    \"previousPageToken\": null\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Filter bank accounts using cursor-based pagination. Use `nextPageToken` or `previousPageToken` from a previous response to navigate pages."
          },
          "response": []
        }
      ]
    }
  ]
}
